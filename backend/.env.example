# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bankofveyda
DATABASE_ECHO=True

# FastAPI
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Sandbox APIs
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_key_here

ONFIDO_API_TOKEN=your_onfido_token_here
ONFIDO_SANDBOX_URL=https://api.sandbox.onfido.com

PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Account Configuration
DEFAULT_ACCOUNT_TTL_DAYS=30
RISK_SCORE_THRESHOLD=75
HIGH_VALUE_TRANSACTION_LIMIT=5000
HIGH_VALUE_TIME_WINDOW_HOURS=1

# Logging
LOG_LEVEL=INFO
